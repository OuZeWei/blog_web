---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/posts/', label: '文章' },
  { href: '/about/', label: '关于' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-100 border-b border-gray-200 bg-white/85 backdrop-blur-md">
  <div class="container-main flex items-center justify-between h-15">
    <a href="/" class="text-xl font-bold text-gray-900 tracking-tight hover:text-brand-600 transition-colors">TechBlog</a>
    <nav class="flex gap-1" aria-label="主导航">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 ${
              currentPath === item.href
                ? 'text-brand-600 bg-brand-50'
                : 'text-gray-500 hover:text-brand-600 hover:bg-gray-50'
            }`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
